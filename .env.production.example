# literary-master v2.5 — production environment template.
# Copy to .env.production (which is git-ignored) before running `npm run start`.

# ── Models ─────────────────────────────────────────────────
# Default analysis model (locked in by bilingual constraint — see
# model-test-on-dgx/reports/2026-05-02_gptoss20_vs_gemma4_multiaxis.md).
ANALYSIS_MODEL=bjoernb/gemma4-26b-fast

# F-1 fallback for structural-integrity LLM calls (Profile merge,
# Synthesis merge, Stage 4b enrichment). qwen3 is the JSON-robustness
# keeper from model-test-on-dgx multi-axis evaluations.
FALLBACK_MODEL=qwen3:30b-a3b-instruct-2507-q4_K_M

# F-2 adversarial cross-check (only fires when Verify v2 returns
# UNCERTAIN). 65 GB model — only enable on hardware ≥ 128 GB unified mem.
# Leave commented to keep run cost predictable.
# ADVERSARIAL_VERIFY_MODEL=gpt-oss:120b

# Per-stage model routing — gpt-oss family disqualified for Korean block
# translation (마기 → 마귀 semantic error documented in model-test-on-dgx).
# Leave commented unless you have a verified Korean-safe alternative.
# BLOCK_BATCH_MODEL=

# Multi-Gloss layer angle overrides — defaults read inside multi-gloss-agent.
# Set only if a model becomes unavailable on the local Ollama instance.
# MULTI_GLOSS_TEXTUAL_MODEL=gpt-oss:120b
# MULTI_GLOSS_CRITICAL_MODEL=qwen3:30b-a3b-instruct-2507-q4_K_M

# ── Pipeline ───────────────────────────────────────────────
# Block batch parallelism. 2 = sweet spot (1.6-1.93x speedup).
# 3+ tested slower due to memory-bandwidth contention on DGX Spark.
BATCH_PARALLELISM=2

# Ollama context size for analysis. 32K covers typical chapter-length input.
OLLAMA_CTX=32768

# v2.5 multi-perspective enrichment. Default true; set "false" to fall back
# to v2-baseline 12-field synthesis output.
MULTI_GLOSS=true

# Block-level Korean Proofreader. Adds ~5 min on a 159-block analysis;
# leave off for production budget runs and turn on for "publication grade".
PROOFREAD_BLOCKS=false

# ── Storage / Logs ────────────────────────────────────────
# Teaching material persistence. Default is data/teaching-materials/ inside
# this project. Override to keep the data outside the project tree if
# preferred (e.g. /var/lib/literary-master-v2/teaching-materials).
# TEACHING_MATERIAL_DIR=

# /api/teaching-material listing endpoint. Disabled by default in
# production; enable for single-user setups.
TEACHING_MATERIAL_LIST_ENABLED=true

# ── Throttling ────────────────────────────────────────────
# Hard cap on input text length. Above this returns 413. 200 KB roughly
# covers one short story. Long-form mode (>5 KB synchronous wait) is a
# UX issue tracked in the production budget findings report.
ANALYZE_MAX_CHARS=200000

# Concurrent analyze requests. Higher numbers contend for Ollama GPU
# memory bandwidth and tend to slow each request down rather than speed
# up throughput. 2 is a tested upper bound on DGX Spark.
ANALYZE_MAX_CONCURRENT=2

# ── Ollama endpoint ──────────────────────────────────────
# Override only if Ollama runs on a non-default URL.
# OLLAMA_URL=http://localhost:11434/api/chat
